GEMINI_API_KEY=
PORT=3000

# Optional: enables real phone-call provider checks in the platform.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Required for real Twilio callbacks. Use an HTTPS public URL in production.
PUBLIC_BASE_URL=

# Optional: outbound webhook timeout in milliseconds.
WEBHOOK_TIMEOUT_MS=10000
