# General
NODE_ENV=development
PORT=3000

# Security
GEMINI_API_KEY=your_gemini_api_key

# PostgreSQL
DATABASE_URL=postgresql://devuser:devpassword@localhost:5432/birthvoices?schema=public

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# JWT and Access
JWT_SECRET=your_jwt_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# Comma-separated list of origins allowed to call the API / connect via Socket.IO
ALLOWED_ORIGINS=http://localhost:3000

# Telephony (Twilio inbound voice)
# TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN come from the Twilio Console. PUBLIC_BASE_URL must be
# the exact public HTTPS URL registered as the Twilio number's webhook (e.g. your Cloud Run URL,
# or an ngrok tunnel for local testing) — it's used to verify the Twilio request signature.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
PUBLIC_BASE_URL=https://your-public-domain.example.com
# Optional: routes calls to a number with no Agent.phoneNumber match to this agent instead of
# hanging up — useful to get a single number working before wiring up per-number assignment.
# The agent's own tenantId is used, so no separate DEFAULT_TENANT_ID is needed.
DEFAULT_AGENT_ID=
