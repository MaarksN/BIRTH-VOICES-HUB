# General
NODE_ENV=development
PORT=3000

# Security
GEMINI_API_KEY=your_gemini_api_key

# Optional: only required if the LLM fallback chain routes to these providers
# (see lib/voice-runtime/providers/LLMGateway.ts). GEMINI_API_KEY alone is
# sufficient for the app to function — Gemini is the guaranteed fallback.
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# PostgreSQL
DATABASE_URL=postgresql://devuser:devpassword@localhost:5432/birthvoices?schema=public

# Redis / BullMQ
# Required in production — the server now fails fast at startup instead of
# silently falling back to localhost when this is unset and NODE_ENV=production.
REDIS_URL=redis://localhost:6379

# JWT and Access
JWT_SECRET=your_jwt_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# Comma-separated list of origins allowed to call the API / connect via Socket.IO
ALLOWED_ORIGINS=http://localhost:3000

