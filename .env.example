# Birth Voices Hub environment template
# Copy to .env for local development only. Never commit real values.

# Runtime
# Type: enum(development,test,production). Required: no. Default: development in dev scripts.
NODE_ENV=development

# Type: integer TCP port. Required: no. Default: 3000.
PORT=3000

# Type: filesystem path. Required: no. Default: ./data.
BIRTH_VOICES_DATA_DIR=./data

# AI / Gemini
# Type: secret string issued by Google AI Studio or Google Cloud. Required: only for real Gemini analysis.
GEMINI_API_KEY=

# Backward-compatible build-time alias used by Vite config. Prefer GEMINI_API_KEY.
# Type: secret string. Required: no.
API_KEY=

# Twilio telephony
# Type: secret/account SID from Twilio. Required: only for real outbound phone calls.
TWILIO_ACCOUNT_SID=

# Type: secret auth token from Twilio. Required: only for real Twilio calls and callback signature validation.
TWILIO_AUTH_TOKEN=

# Type: E.164 phone number. Required: only for real outbound phone calls.
TWILIO_FROM_NUMBER=

# Type: HTTPS public URL with no trailing slash. Required: production Twilio callbacks.
PUBLIC_BASE_URL=

# Webhooks
# Type: integer milliseconds. Required: no. Default: 10000.
WEBHOOK_TIMEOUT_MS=10000

# Type: boolean string. Required: no. Use only in non-production integration tests.
ALLOW_LOCAL_WEBHOOKS_FOR_TESTS=false

# Rate limiting
# Type: integer milliseconds. Required: no. Default: 60000.
RATE_LIMIT_WINDOW_MS=60000

# Type: integer requests per RATE_LIMIT_WINDOW_MS. Required: no. Default: 240.
API_RATE_LIMIT_MAX=240

# Type: integer milliseconds. Required: no. Default: 900000.
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Type: integer requests per AUTH_RATE_LIMIT_WINDOW_MS. Required: no. Default: 20.
AUTH_RATE_LIMIT_MAX=20

# Type: integer requests per RATE_LIMIT_WINDOW_MS. Required: no. Default: 120.
WEBHOOK_RATE_LIMIT_MAX=120

# Privacy and retention
# Type: semantic date/version string. Required: no. Default: current terms version in server.
PRIVACY_TERMS_VERSION=2026-06-05

# Type: integer days. Required: no. Default: 365.
DATA_RETENTION_DAYS=365

# Observability
# Type: enum(error,warn,info,debug). Required: no. Default: info.
LOG_LEVEL=info

# Type: DSN URL secret. Required: no. Only when external error telemetry is enabled.
SENTRY_DSN=

# AI timeout
# Type: integer milliseconds. Required: no. Default: 15000.
AI_TIMEOUT_MS=15000
