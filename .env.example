# Runtime
NODE_ENV=development
PORT=3000

# Security
GEMINI_API_KEY=your_gemini_api_key

# Optional AI providers — each is checked at call time; features fall back to a
# "not configured" response if unset, the app does not fail to start without them.
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# PostgreSQL
DATABASE_URL=postgresql://devuser:devpassword@localhost:5432/birthvoices?schema=public

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# JWT and Access — required; the server throws on startup of the first auth
# operation if either is unset (src/lib/auth-tokens.ts#requireSecret).
JWT_SECRET=your_jwt_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# Comma-separated list of origins allowed to call the API / connect via Socket.IO
ALLOWED_ORIGINS=http://localhost:3000
